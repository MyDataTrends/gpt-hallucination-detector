{
  "manifest_version": 3,
  "name": "GPT Hallucination Detector",
  "description": "Detects potential hallucinations in ChatGPT responses",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "dist/content.js"
      ],
      "css": [
        "src/assets/styles.css"
      ]
    }
  ]
}